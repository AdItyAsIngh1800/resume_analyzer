# ── Server ────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/resume-analyzer
# Atlas:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/resume-analyzer
MONGODB_URI=mongodb://localhost:27017/resume-analyzer

# ── Auth ──────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Backend ────────────────────────────────────────────────────────
# Set GEMINI_API_KEY for cloud deployment (Render, Railway, etc.)
# Leave blank to use local Ollama instead.
#
# Get a free Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local dev only — ignored when GEMINI_API_KEY is set)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Frontend ──────────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
