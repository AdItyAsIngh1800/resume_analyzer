# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_public_key_here

# Backend
PORT=5000
MONGODB_URI=mongodb://localhost:27017/resume-analyzer
MONGODB_DB_NAME=resume-analyzer
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development

# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=resume-analyzer-uploads
AWS_REGION=us-east-1

# Stripe (payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Redis
REDIS_URL=redis://localhost:6379

# Python Service
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_API_KEY=your_python_service_key

# Email (for notifications)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDER_EMAIL=noreply@resumeanalyzer.app

# Logging
LOG_LEVEL=info
